<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="KeepPCAwakeApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:KeepPCAwakeApp"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Keep PC Awake">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Padding="20">
        <Grid
            Width="500"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="6" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="14" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- App title -->
            <TextBlock
                Grid.Row="0"
                Text="Keep PC Awake"
                FontSize="18"
                FontWeight="SemiBold"
                HorizontalAlignment="Left" />

            <!-- Small explanation -->
            <TextBlock
                Grid.Row="2"
                Text="Prevents your PC from sleeping until you turn it off, or until the optional timer runs out."
                TextWrapping="Wrap"
                Opacity="0.8"
                FontSize="12"
                HorizontalAlignment="Left" />

            <!-- Main controls -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Main awake toggle -->
                <ToggleSwitch
                    Grid.Column="0"
                    x:Name="KeepAwakeToggle"
                    Width="90"
                    OffContent=""
                    OnContent=""
                    HorizontalAlignment="Left"
                    Toggled="KeepAwakeToggle_Toggled" />

                <!-- Enables the optional timer -->
                <CheckBox
                    Grid.Column="2"
                    x:Name="AutoOffCheckBox"
                    Content="Auto off"
                    IsChecked="False"
                    VerticalAlignment="Center" />

                <!-- Minutes until auto-off -->
                <NumberBox
                    Grid.Column="4"
                    x:Name="MinutesNumberBox"
                    Value="30"
                    Minimum="1"
                    Maximum="1440"
                    SmallChange="1"
                    MinWidth="180"
                    HorizontalAlignment="Stretch"
                    SpinButtonPlacementMode="Hidden" />
            </Grid>

            <!-- Current state -->
            <TextBlock
                Grid.Row="6"
                x:Name="StatusText"
                Text="Feeling sleepy. Might fall asleep"
                HorizontalAlignment="Left"
                TextWrapping="Wrap" />
        </Grid>
    </Grid>
</Window>